---
import type { CollectionEntry } from "astro:content";
import { getCategoryBySlug } from "../config/site";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, pubDate, category, image } = post.data;
const cat = getCategoryBySlug(category);
const dateStr = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article
  class:list={[
    "group rounded-xl border border-ink-200 bg-white overflow-hidden hover:shadow-lg hover:border-brand-300 transition-all duration-200",
    featured ? "md:flex" : "",
  ]}
>
  {featured && (
    <div class="md:w-2/5 aspect-video md:aspect-auto bg-gradient-to-br from-brand-400 to-brand-700 relative overflow-hidden">
      <div class="absolute inset-0 flex items-center justify-center text-white/90 p-8">
        <svg class="w-16 h-16 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.456-2.456L14.25 6l1.035-.259a3.375 3.375 0 002.456-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/>
        </svg>
      </div>
    </div>
  )}

  <div class:list={["p-5 flex flex-col", featured ? "md:w-3/5" : ""]}>
    <div class="flex items-center gap-2 mb-3">
      {cat && (
        <a
          href={`/categories/${cat.slug}/`}
          class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-50 text-brand-700 hover:bg-brand-100 transition-colors"
        >
          {cat.name}
        </a>
      )}
      <time class="text-xs text-ink-400" datetime={pubDate.toISOString()}>
        {dateStr}
      </time>
    </div>

    <h3 class:list={["font-bold text-ink-900 group-hover:text-brand-600 transition-colors", featured ? "text-xl md:text-2xl" : "text-lg"]}>
      <a href={`/blog/${post.id}/`}>
        {title}
      </a>
    </h3>

    <p class="mt-2 text-sm text-ink-600 line-clamp-2 flex-1">
      {description}
    </p>

    <a
      href={`/blog/${post.id}/`}
      class="mt-4 inline-flex items-center text-sm font-medium text-brand-600 hover:text-brand-700"
      aria-label={`Read more about ${title}`}
    >
      Read more
      <svg class="w-4 h-4 ml-1 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
