---
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"blog">[];
  title?: string;
}

const { posts, title = "All Articles" } = Astro.props;
---

{posts.length > 0 && (
  <section class="mt-12">
    <h2 class="text-2xl font-bold text-ink-900 mb-6">{title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map((post) => (
        <article class="group rounded-xl border border-ink-200 p-5 hover:shadow-md hover:border-brand-300 transition-all">
          <div class="flex items-center gap-2 mb-2 text-xs">
            <span class="font-medium text-brand-600">{post.data.category}</span>
            <span class="text-ink-300">&middot;</span>
            <time class="text-ink-400" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
            </time>
          </div>
          <h3 class="font-bold text-ink-900 group-hover:text-brand-600 transition-colors">
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
          </h3>
          <p class="mt-2 text-sm text-ink-600 line-clamp-2">{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>
)}
