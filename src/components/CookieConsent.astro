--- 
// Cookie Consent Banner with Google Consent Mode v2
---

<div id="cookie-consent" class="cookie-consent hidden">
  <div class="cookie-content">
    <div class="cookie-text">
      <p>
        We use cookies to improve your experience and analyze site traffic. 
        By clicking "Accept", you consent to the use of cookies. 
        See our <a href="/privacy-policy/">Privacy Policy</a> for details.
      </p>
    </div>
    <div class="cookie-buttons">
      <button id="cookie-reject" class="cookie-btn cookie-btn-reject">
        Reject
      </button>
      <button id="cookie-accept" class="cookie-btn cookie-btn-accept">
        Accept
      </button>
    </div>
  </div>
</div>

<style>
  .cookie-consent {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: #1a1a2e;
    color: #e2e8f0;
    padding: 16px 20px;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
    transform: translateY(100%);
    transition: transform 0.4s ease-out;
  }

  .cookie-consent.show {
    transform: translateY(0);
  }

  .cookie-content {
    max-width: 768px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .cookie-text {
    flex: 1;
    min-width: 280px;
  }

  .cookie-text p {
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
    color: #cbd5e1;
  }

  .cookie-text a {
    color: #38bdf8;
    text-decoration: underline;
  }

  .cookie-text a:hover {
    color: #7dd3fc;
  }

  .cookie-buttons {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .cookie-btn {
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .cookie-btn-accept {
    background: #0ea5e9;
    color: white;
  }

  .cookie-btn-accept:hover {
    background: #0284c7;
  }

  .cookie-btn-reject {
    background: transparent;
    color: #94a3b8;
    border: 1px solid #475569;
  }

  .cookie-btn-reject:hover {
    background: #334155;
    color: #e2e8f0;
  }

  @media (max-width: 640px) {
    .cookie-content {
      flex-direction: column;
      align-items: stretch;
    }

    .cookie-buttons {
      justify-content: flex-end;
    }
  }
</style>

<script is:inline>
  (function () {
    const CONSENT_KEY = 'cookie-consent-v1';
    const banner = document.getElementById('cookie-consent');
    
    // Don't show if already decided
    const existing = localStorage.getItem(CONSENT_KEY);
    if (existing) {
      // Apply stored consent on page load
      if (existing === 'granted') {
        gtag('consent', 'update', {
          'ad_storage': 'granted',
          'ad_user_data': 'granted',
          'ad_personalization': 'granted',
          'analytics_storage': 'granted'
        });
      }
      // If 'denied', default consent (all denied) stays in effect
      return;
    }

    // Show banner after a short delay
    setTimeout(function () {
      banner.classList.remove('hidden');
      requestAnimationFrame(function () {
        banner.classList.add('show');
      });
    }, 800);

    function handleAccept() {
      localStorage.setItem(CONSENT_KEY, 'granted');
      gtag('consent', 'update', {
        'ad_storage': 'granted',
        'ad_user_data': 'granted',
        'ad_personalization': 'granted',
        'analytics_storage': 'granted'
      });
      banner.classList.remove('show');
      setTimeout(function () {
        banner.classList.add('hidden');
      }, 400);
    }

    function handleReject() {
      localStorage.setItem(CONSENT_KEY, 'denied');
      gtag('consent', 'update', {
        'ad_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied',
        'analytics_storage': 'denied'
      });
      banner.classList.remove('show');
      setTimeout(function () {
        banner.classList.add('hidden');
      }, 400);
    }

    document.getElementById('cookie-accept').addEventListener('click', handleAccept);
    document.getElementById('cookie-reject').addEventListener('click', handleReject);
  })();
</script>
