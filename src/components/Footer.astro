---
import { SITE, CATEGORIES } from "../config/site";

const year = new Date().getFullYear();
---

<footer class="bg-ink-900 text-ink-300 mt-20">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 font-bold text-lg text-white mb-3">
          <svg class="w-7 h-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="#0ea5e9"/>
            <path d="M10 12L16 8L22 12V20L16 24L10 20V12Z" stroke="white" stroke-width="2" stroke-linejoin="round"/>
            <circle cx="16" cy="16" r="3" fill="white"/>
          </svg>
          AI Kit Guides
        </a>
        <p class="text-sm leading-relaxed max-w-md">
          AI tool tutorials, honest comparisons, and beginner-friendly guides. Helping you find and master the best AI tools available today.
        </p>
        <div class="flex gap-4 mt-4">
          <a href={SITE.social.twitter} class="text-ink-400 hover:text-brand-400 transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href={SITE.social.github} class="text-ink-400 hover:text-brand-400 transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
          <a href="/rss.xml" class="text-ink-400 hover:text-brand-400 transition-colors" aria-label="RSS">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20A2.18 2.18 0 014 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1Z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Categories</h3>
        <ul class="space-y-2 text-sm">
          {CATEGORIES.map((cat) => (
            <li>
              <a href={`/categories/${cat.slug}/`} class="hover:text-brand-400 transition-colors">
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Site</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/about/" class="hover:text-brand-400 transition-colors">About</a></li>
          <li><a href="/contact/" class="hover:text-brand-400 transition-colors">Contact</a></li>
          <li><a href="/privacy-policy/" class="hover:text-brand-400 transition-colors">Privacy Policy</a></li>
          <li><a href="/rss.xml" class="hover:text-brand-400 transition-colors">RSS Feed</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-ink-700 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-ink-400">
        &copy; {year} AI Kit Guides. All rights reserved.
      </p>
      <p class="text-xs text-ink-500">
        Built with Astro &amp; Tailwind CSS. Powered by curiosity about AI.
      </p>
    </div>
  </div>
</footer>
