---
import { SITE } from "../config/site";

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};
---

<header
  class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-ink-200"
  style="height: var(--header-height)"
>
  <div class="max-w-6xl mx-auto px-4 h-full flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-ink-900 hover:text-brand-600 transition-colors">
      <svg class="w-7 h-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="8" fill="#0ea5e9"/>
        <path d="M10 12L16 8L22 12V20L16 24L10 20V12Z" stroke="white" stroke-width="2" stroke-linejoin="round"/>
        <circle cx="16" cy="16" r="3" fill="white"/>
      </svg>
      <span>AI Kit Guides</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {SITE.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-2 rounded-md text-sm font-medium transition-colors",
            isActive(item.href)
              ? "text-brand-600 bg-brand-50"
              : "text-ink-600 hover:text-brand-600 hover:bg-ink-50",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/rss.xml"
        class="text-ink-400 hover:text-brand-600 transition-colors"
        aria-label="RSS Feed"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20A2.18 2.18 0 014 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1Z"/>
        </svg>
      </a>
      <a
        href="/blog/"
        class="hidden sm:inline-flex items-center px-4 py-2 rounded-lg bg-brand-600 text-white text-sm font-medium hover:bg-brand-700 transition-colors"
      >
        Read Articles
      </a>
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-ink-600"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-ink-200 bg-white">
    <nav class="px-4 py-3 flex flex-col gap-1">
      {SITE.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-2 rounded-md text-sm font-medium",
            isActive(item.href)
              ? "text-brand-600 bg-brand-50"
              : "text-ink-600 hover:bg-ink-50",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
