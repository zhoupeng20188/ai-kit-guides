---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AdScript from "../components/AdScript.astro";
import BaseSEO from "../components/BaseSEO.astro";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  faqJsonLd?: object[];
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseSEO {...props} />
    <AdScript />
  </head>
  <body class="min-h-screen flex flex-col bg-white dark:bg-ink-50">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
