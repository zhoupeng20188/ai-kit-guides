---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout noindex={true}>
  <div class="max-w-xl mx-auto px-4 py-20 text-center">
    <p class="text-8xl font-extrabold text-brand-600 mb-4">404</p>
    <h1 class="text-3xl font-bold text-ink-900 mb-3">Page Not Found</h1>
    <p class="text-ink-600 mb-8">
      The page you're looking for doesn't exist or has been moved. Let's get you back on track.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/"
        class="inline-flex items-center px-6 py-3 rounded-lg bg-brand-600 text-white font-medium hover:bg-brand-700 transition-colors"
      >
        Back to Home
      </a>
      <a
        href="/blog"
        class="inline-flex items-center px-6 py-3 rounded-lg border border-ink-300 text-ink-700 font-medium hover:border-brand-400 hover:text-brand-600 transition-colors"
      >
        Browse Articles
      </a>
    </div>
  </div>
</MainLayout>
