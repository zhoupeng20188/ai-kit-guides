---
import MainLayout from "../../layouts/MainLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import { CATEGORIES } from "../../config/site";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<MainLayout
  title="Blog"
  description="Browse all AI tool tutorials, reviews, and comparison guides. Learn how to use ChatGPT, Claude, Midjourney, and more."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <header class="mb-10 text-center">
      <h1 class="text-4xl font-extrabold text-ink-900 mb-3">The Blog</h1>
      <p class="text-lg text-ink-600 max-w-2xl mx-auto">
        In-depth guides and honest reviews covering the best AI tools available today. New articles published weekly.
      </p>
    </header>

    <!-- Category filter pills -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-10">
      <a
        href="/blog"
        class="px-4 py-1.5 rounded-full text-sm font-medium bg-brand-600 text-white"
      >
        All
      </a>
      {CATEGORIES.map((cat) => (
        <a
          href={`/categories/${cat.slug}`}
          class="px-4 py-1.5 rounded-full text-sm font-medium bg-ink-100 text-ink-600 hover:bg-brand-50 hover:text-brand-700 transition-colors"
        >
          {cat.name}
        </a>
      ))}
    </div>

    <!-- Article Grid -->
    {sortedPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <ArticleCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-ink-400">
        <p class="text-lg">No articles yet. Check back soon!</p>
      </div>
    )}
  </div>
</MainLayout>
