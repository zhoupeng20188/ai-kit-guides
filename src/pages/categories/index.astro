---
import MainLayout from "../../layouts/MainLayout.astro";
import { CATEGORIES } from "../../config/site";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
---

<MainLayout
  title="Categories"
  description="Browse AI tool guides by category — ChatGPT, AI Tools, Prompt Engineering, AI Art, and Large Language Models."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <header class="mb-10 text-center">
      <h1 class="text-4xl font-extrabold text-ink-900 mb-3">Categories</h1>
      <p class="text-lg text-ink-600 max-w-2xl mx-auto">
        Explore our AI tool guides organized by topic. Whether you're getting started with ChatGPT or mastering prompt engineering, we've got you covered.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {CATEGORIES.map((cat) => {
        const count = posts.filter((p) => p.data.category === cat.slug).length;
        return (
          <a
            href={`/categories/${cat.slug}`}
            class="group rounded-2xl border border-ink-200 p-8 hover:border-brand-400 hover:shadow-lg transition-all"
          >
            <div class="text-4xl mb-4">
              {cat.icon === "chat" && "💬"}
              {cat.icon === "tools" && "🔧"}
              {cat.icon === "prompt" && "✏️"}
              {cat.icon === "art" && "🎨"}
              {cat.icon === "brain" && "🧠"}
            </div>
            <h2 class="text-xl font-bold text-ink-900 group-hover:text-brand-600 transition-colors mb-2">
              {cat.name}
            </h2>
            <p class="text-sm text-ink-600 leading-relaxed">{cat.description}</p>
            <p class="mt-4 text-sm font-medium text-brand-600">
              {count} article{count !== 1 ? "s" : ""} &rarr;
            </p>
          </a>
        );
      })}
    </div>
  </div>
</MainLayout>
