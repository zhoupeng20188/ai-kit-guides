---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE } from "../config/site";
---

<MainLayout
  title="Contact"
  description="Get in touch with the AI Kit Guides team. We'd love to hear your questions, feedback, and suggestions."
>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-ink-900 mb-6">Contact Us</h1>

    <p class="text-lg text-ink-600 mb-8">
      Have a question about an AI tool? Want to suggest a topic for our next article? Or just want to share your thoughts? We're listening.
    </p>

    <div class="space-y-6">
      <div class="rounded-xl border border-ink-200 p-6">
        <h2 class="font-semibold text-ink-900 mb-2 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Email
        </h2>
        <p class="text-ink-600">
          <a href={`mailto:${SITE.email}`} class="text-brand-600 link-underline">{SITE.email}</a>
        </p>
      </div>

      <div class="rounded-xl border border-ink-200 p-6">
        <h2 class="font-semibold text-ink-900 mb-2 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20A2.18 2.18 0 014 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1Z"/>
          </svg>
          RSS Feed
        </h2>
        <p class="text-ink-600">
          Subscribe to our <a href="/rss.xml" class="text-brand-600 link-underline">RSS feed</a> to get notified about new articles.
        </p>
      </div>
    </div>

    <div class="mt-10 p-6 rounded-xl bg-brand-50 border border-brand-100">
      <h2 class="font-semibold text-ink-900 mb-2">Response Time</h2>
      <p class="text-sm text-ink-600">
        We typically respond to emails within 1-2 business days. For urgent inquiries, please mention "URGENT" in the subject line.
      </p>
    </div>
  </div>
</MainLayout>
